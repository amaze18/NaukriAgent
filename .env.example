# NaukriAgent Environment Configuration
# Copy this to .env and update with your values

# ============================================
# SLM (Small Language Model) Configuration
# ============================================

# Model name/identifier for your fine-tuned model
SLM_MODEL_NAME=phi-3-fine-tuned-hr

# Base URL for your LLM provider
# Ollama default: http://localhost:11434/v1
# vLLM default: http://localhost:8000/v1
SLM_BASE_URL=http://localhost:11434/v1

# API key for the SLM provider
# Ollama uses: ollama
SLM_API_KEY=ollama

# ============================================
# Application Configuration
# ============================================

# Enable human-in-the-loop approval gate
APPROVAL_REQUIRED=true

# Minimum score threshold for candidate to proceed (0-100)
DEFAULT_SCORE_THRESHOLD=75

# ============================================
# Optional: Database Configuration
# ============================================

# Uncomment and configure for state persistence
# DATABASE_URL=postgresql://user:password@localhost:5432/naukri_agent

# ============================================
# Optional: Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ============================================
# Notes
# ============================================

# For Ollama:
# 1. Install: brew install ollama (macOS) or curl https://ollama.ai/install.sh | sh
# 2. Start: ollama serve
# 3. Pull model: ollama pull phi3

# For vLLM:
# Start: python -m vllm.entrypoints.openai.api_server --model /path/to/model --port 8000
